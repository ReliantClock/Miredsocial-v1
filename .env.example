# ============================================================
#  VARIABLES DE ENTORNO — copia este archivo como .env.local
#  y rellena los valores. NUNCA subas .env.local a git.
# ============================================================

# ── Supabase (OBLIGATORIO si usas Supabase) ───────────────────
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY

# ── Cloudinary (opcional) ─────────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_UPLOAD_PRESET=

# ── Cloudflare R2 (opcional) ──────────────────────────────────
VITE_R2_ACCOUNT_ID=
VITE_R2_ACCESS_KEY_ID=
VITE_R2_SECRET_ACCESS_KEY=
VITE_R2_BUCKET=
VITE_R2_PUBLIC_URL=

# ── Backblaze B2 (opcional) ───────────────────────────────────
VITE_B2_KEY_ID=
VITE_B2_APP_KEY=
VITE_B2_BUCKET_ID=
VITE_B2_BUCKET_NAME=

# ── Oracle Cloud (opcional) ───────────────────────────────────
VITE_ORACLE_NAMESPACE=
VITE_ORACLE_BUCKET=
VITE_ORACLE_REGION=
VITE_ORACLE_ACCESS_KEY=
VITE_ORACLE_SECRET_KEY=

# ── Firebase (opcional) ───────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
